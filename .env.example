# Server
PORT=4001
ENV=development

# MongoDB (own database — separate from main stack)
MONGODB_URI=mongodb://localhost:27017
MONGODB_NAME=91astro_seo

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Google Search Console
# Service account JSON downloaded from Google Cloud Console
# Grant it access to your domain property in GSC
GSC_CREDENTIALS_PATH=./gsc-credentials.json
GSC_SITE_URL=sc-domain:91astrology.com

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# GitHub
# Create a fine-grained PAT with: Contents (write), Pull requests (write)
# on both 91astro-website and 91astro-api repos
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=91astro
WEBSITE_REPO=91astro-website
API_REPO=91astro-api

# 91astro-api (main stack — for executing approved changes)
MAIN_API_URL=https://api.91astrology.com
INTERNAL_API_KEY=generate-a-strong-random-secret

# 91astro-website (Next.js ISR revalidation)
NEXT_REVALIDATE_URL=https://91astrology.com
REVALIDATE_SECRET=generate-a-strong-random-secret

# Dashboard local dev token — set any string, paste it in the browser prompt
# In production, leave empty and use real JWT from 91astro-api login
# This same token is used by 91astro-website as SEO_API_TOKEN
DASHBOARD_TOKEN=dev-secret-change-me

# JWT — MUST match JWT_SECRET in 91astro-api exactly
# This allows admin users logged into the main app to call this API
JWT_SECRET=same-secret-as-main-api

# Email (for weekly reports + rollback alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
REPORT_EMAIL=founder@91astrology.com

# Google Analytics 4
# Service account JSON with Analytics Data API access
GA_PROPERTY_ID=properties/123456789
GA_CREDENTIALS_PATH=./ga-credentials.json

# Datadog RUM
DATADOG_API_KEY=...
DATADOG_APP_KEY=...

# Pinterest API v5 — auto-pins blog posts once their seo-topic is "approved"
# Setup (one-time):
#  1. Create an app at https://developers.pinterest.com (App ID is public)
#  2. Request scopes: pins:write, boards:read
#  3. Run the OAuth authorization-code flow once to get a refresh token
#  4. Create/choose a destination board and copy its ID
PINTEREST_ENABLED=false
PINTEREST_APP_ID=1572971
PINTEREST_APP_SECRET=
PINTEREST_REFRESH_TOKEN=
PINTEREST_BOARD_ID=

# Public URLs for building pin links + images (defaults shown)
WEBSITE_URL=https://www.91astrology.com
CMS_MEDIA_BASE_URL=https://91astro-payload-cms.s3.ap-south-1.amazonaws.com
